# Doxygen template configured by CMake.

PROJECT_NAME           = "@CMAKE_PROJECT_NAME@"
PROJECT_BRIEF          = "Hydroacoustic direction finder firmware"
PROJECT_NUMBER         = "@CMAKE_PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"

CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

INPUT                  = "@CMAKE_SOURCE_DIR@/README.md" \
                         "@CMAKE_SOURCE_DIR@/Core/Inc" \
                         "@CMAKE_SOURCE_DIR@/Core/Src" \
                         "@CMAKE_SOURCE_DIR@/Core/platforms"
FILE_PATTERNS          = *.h *.hpp *.c *.cpp *.md
RECURSIVE              = YES

USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

QUIET                  = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
