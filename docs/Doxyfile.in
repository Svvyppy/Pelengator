# Doxygen template configured by CMake.

PROJECT_NAME           = "@CMAKE_PROJECT_NAME@"
PROJECT_BRIEF          = "Hydroacoustic direction finder firmware"
PROJECT_NUMBER         = "@CMAKE_PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"
PROJECT_LOGO           = "@CMAKE_SOURCE_DIR@/docs/cmsis_style/cmsis_logo_white_small.png"

CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

INPUT                  = "@CMAKE_SOURCE_DIR@/docs/mainpage.md" \
                         "@CMAKE_SOURCE_DIR@/src/peleng/Peleng.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/peleng/Filter.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/peleng/DelayEstimator.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/peleng/UartTelemetry.hpp" \
                         "@CMAKE_SOURCE_DIR@/src/peleng/CommonSettings.h" \
                         "@CMAKE_SOURCE_DIR@/src/platforms/Hw.h"
FILE_PATTERNS          = *.h *.hpp *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */.git/* */Drivers/* */docs/cmsis_style/* */tests/* */stm32_gen/*

USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/docs/mainpage.md"
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
HTML_EXTRA_STYLESHEET  = "@CMAKE_SOURCE_DIR@/docs/cmsis_style/extra_stylesheet.css" \
                         "@CMAKE_SOURCE_DIR@/docs/cmsis_style/extra_navtree.css" \
                         "@CMAKE_SOURCE_DIR@/docs/cmsis_style/extra_tabs.css" \
                         "@CMAKE_SOURCE_DIR@/docs/cmsis_style/extra_search.css" \
                         "@CMAKE_SOURCE_DIR@/docs/cmsis_style/version.css"
TOC_INCLUDE_HEADINGS   = 2

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_UNDOC_RELATIONS   = YES
ALPHABETICAL_INDEX     = NO
SHOW_FILES             = NO
SHOW_NAMESPACES        = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

QUIET                  = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
