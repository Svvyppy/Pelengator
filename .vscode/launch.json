{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/Peleng.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "device": "STM32G474xx",
            "preResetCommands": [
                "monitor reset halt",
                "monitor reg pc 0x08000000",
                "monitor resume",
                "monitor halt"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            // "svdFile": "Drivers/Hydrodrivers/resources/STM32F103.svd",
            "showDevDebugOutput": "raw",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ]
        }
    ]
}